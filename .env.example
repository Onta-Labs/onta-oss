# Graph database backend: "neptune" or "fuseki"
OMNIX_GRAPH_BACKEND=fuseki
OMNIX_NEPTUNE_ENDPOINT=http://localhost:3030

# LLM API keys (at least one required)
OPENROUTER_API_KEY=sk-or-...

# Optional: for type matching (falls back to OpenRouter if not set)
# OMNIX_ANTHROPIC_API_KEY=sk-ant-...

# Optional: for fast inference
# OMNIX_CEREBRAS_API_KEY=csk-...

# Optional: API key authentication (empty = open access, no auth needed)
# OMNIX_API_KEYS={"my-key": "my-tenant"}

# ---------------------------------------------------------------------------
# Bring-your-own-key registry sources (ONTA-340)
# ---------------------------------------------------------------------------
# Keyed entries in the built-in API-source registry are BRING-YOUR-OWN-KEY:
# each one stays DORMANT until you register for the provider's own (free) key
# and put it in your environment here. This OSS build never ships or implies a
# shared/platform key — "managed" keys (we provision, hold, meter, and bill the
# credential) are a premium/hosted-only feature. Unkeyed seeds
# (NPPES, ClinicalTrials.gov, Open Food Facts) need nothing.
#
# GEONAMES_USERNAME=...   # free GeoNames account — geocoding / place lookups.
#                         # Register: https://www.geonames.org/login
# FRED_API_KEY=...        # free St. Louis Fed key — U.S. national average prices
#                         # (BLS AP series). Register: https://fredaccount.stlouisfed.org/apikeys

# Optional: local key that envelope-encrypts per-workspace API credentials you
# store server-side (the tenant_custom secret store — still your OWN keys, just
# encrypted at rest). Required only to store secrets via the API-sources routes.
# OMNIX_SECRETS_KEY=<base64 32-byte key>   # e.g. `openssl rand -base64 32`
