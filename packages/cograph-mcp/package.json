{
  "name": "cograph-mcp",
  "version": "0.1.28",
  "description": "Onta (formerly Cograph) MCP server — expose context graph tools to AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cograph-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
