    "directory": "packages/cograph-mcp"
  },
  "bugs": {
    "url": "https://github.com/git-moeen/onta-oss/issues"
  },
  "dependencies": {
    "cograph": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
