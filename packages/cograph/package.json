{
  "name": "@onta/cli",
  "version": "0.1.55",
  "description": "Onta SDK and CLI — context graph platform for structured data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "onta": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "node ../../scripts/chmod-bin.js packages/cograph/dist/cli.js"
  },
  "keywords": [
    "knowledge-graph",
    "context-graph",
    "onta",
    "sdk",
    "cli",
    "rdf",
    "sparql",
    "ontology",
    "ai",
    "llm"
  ],
  "author": "Onta",
  "license": "Apache-2.0",
  "homepage": "https://getonta.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Onta-Labs/onta-oss.git",
    "directory": "packages/cograph"
  },
  "bugs": {
    "url": "https://github.com/Onta-Labs/onta-oss/issues"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
